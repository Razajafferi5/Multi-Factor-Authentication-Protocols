# Copy to .streamlit/secrets.toml for local Streamlit, or paste into the
# "Secrets" box in Streamlit Community Cloud (Settings -> Secrets).
#
# --- Option 1: dashboard talks to a remotely deployed Flask API -------------
# EMBEDDED = "0"
# API_BASE_URL = "https://your-mfa-api.onrender.com"
#
# --- Option 2: single-container demo (dashboard runs the backend in-process) -
EMBEDDED = "1"
DATABASE_URL = "sqlite:///mfa.db"
# 32-byte base64 master key. Generate with:
#   python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
MASTER_KEY = "REPLACE_WITH_BASE64_32_BYTE_KEY"
SECRET_KEY = "REPLACE_WITH_RANDOM_STRING"

# Optional: enables Claude explanations. Omit to use graceful fallback.
# ANTHROPIC_API_KEY = "sk-ant-..."
# ANTHROPIC_MODEL = "claude-3-5-haiku-latest"
