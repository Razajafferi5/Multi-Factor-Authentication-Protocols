# ---------------------------------------------------------------------------
# MFA Authentication Server - environment configuration
# Copy this file to ".env" and fill in real values for local development.
# ---------------------------------------------------------------------------

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-flask-session-key

# Database (SQLAlchemy URL). Default is a local SQLite file.
DATABASE_URL=sqlite:///mfa.db

# ---------------------------------------------------------------------------
# Server master key for the AES-256-GCM secret vault.
# Generate one with:
#   python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
# This is the ROOT of trust for all encrypted TOTP/HOTP secrets at rest.
# See SECURITY_NOTES.md for the key-management limitation.
# ---------------------------------------------------------------------------
MASTER_KEY=

# ---------------------------------------------------------------------------
# WebAuthn / FIDO2 relying-party configuration.
# RP_ID must match the domain the browser sees (no scheme, no port).
# RP_ORIGIN is the full origin including scheme.
# ---------------------------------------------------------------------------
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=MFA Capstone Server
WEBAUTHN_RP_ORIGIN=http://localhost:5000

# ---------------------------------------------------------------------------
# Anthropic Claude API for natural-language anomaly explanations.
# OPTIONAL: if unset or unreachable, the system degrades gracefully and shows
# the raw anomaly features instead of prose.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ---------------------------------------------------------------------------
# Security tuning
# ---------------------------------------------------------------------------
# Failed-attempt threshold before lockout / CAPTCHA is required.
LOCKOUT_MAX_FAILURES=5
# Sliding window (seconds) over which failures are counted.
LOCKOUT_WINDOW_SECONDS=300
# Lockout duration (seconds) once tripped.
LOCKOUT_DURATION_SECONDS=900

# ---------------------------------------------------------------------------
# Streamlit dashboard wiring
# ---------------------------------------------------------------------------
# If API_BASE_URL is set, the dashboard talks to a remote Flask API over HTTP.
API_BASE_URL=http://localhost:5000
# If EMBEDDED=1, the dashboard imports the service layer in-process instead
# (used for single-container Streamlit Cloud demos).
EMBEDDED=0
